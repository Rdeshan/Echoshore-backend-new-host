# Core
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<dbName>
JWT_SECRET=<strong-random-secret>
JWT_EXPIRES_IN=7d

# Frontend/Auth/ML
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
ML_SERVICE_URL=http://localhost:5001
ML_TRAIN_SECRET=<strong-random-secret>
WEATHER_API_KEY=<weather-api-key>

# Email (optional)
GMAIL_USER=<gmail-address>
GMAIL_APP_PASSWORD=<gmail-app-password>

# Firebase Admin (preferred: individual fields)
FIREBASE_DATABASE_URL=https://<project-id>-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_CLIENT_EMAIL=<service-account-email>
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY_ID=<private-key-id>
FIREBASE_CLIENT_ID=<client-id>
FIREBASE_CLIENT_X509_CERT_URL=<x509-cert-url>

# Optional alternative (instead of individual FIREBASE_* fields)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
